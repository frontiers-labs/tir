// Hand-written checks for the SMT-LIB backend's behavior emission: width
// tracking, sign/zero extension, comparisons, PC access, memory accesses,
// try/except trap modeling, and the UNSUPPORTED-BEHAVIOR marker. Do not
// regenerate with update_checks.py.

// RUN: tmdlc --action=emit-smtlib --dialect=test --isa=TestIsa --output=- %S/../Inputs/smtlib.tmdl | filecheck %s

// State: register-file arrays, byte-addressable memory, the program counter.
// CHECK: (declare-datatypes () ((TMDLState (mk-TMDLState (csr (Array (_ BitVec 12) (_ BitVec 64))) (gpr (Array (_ BitVec 5) (_ BitVec 64))) (mem (Array (_ BitVec 64) (_ BitVec 8))) (pc (_ BitVec 64))))))

// Little-endian memory accessors: byte at addr is the least significant.
// CHECK: (define-fun read_mem_4 ((st TMDLState) (addr (_ BitVec 64))) (_ BitVec 32)
// CHECK-NEXT: (concat (concat (concat (select (mem st) (bvadd addr (_ bv3 64))) (select (mem st) (bvadd addr (_ bv2 64)))) (select (mem st) (bvadd addr (_ bv1 64)))) (select (mem st) addr)))

// CHECK: ; INSTRUCTION: tadd writes-pc=false rd:reg:gpr:5 rs1:reg:gpr:5 rs2:reg:gpr:5
// CHECK: (define-fun execute_tadd ((st TMDLState) (rd (_ BitVec 5)) (rs1 (_ BitVec 5)) (rs2 (_ BitVec 5))) TMDLState
// CHECK-NEXT: (write_gpr st rd (bvadd (read_gpr st rs1) (read_gpr st rs2))))

// The shift amount is the low log2(XLEN) bits of rs2, widened back to 64.
// CHECK: (define-fun execute_tshift
// CHECK-NEXT: (write_gpr st rd (bvshl (read_gpr st rs1) ((_ zero_extend 58) ((_ extract 5 0) (read_gpr st rs2)))))

// Comparisons are Bool-sorted and only materialize as bitvectors at the ite.
// CHECK: (define-fun execute_tslt
// CHECK-NEXT: (write_gpr st rd (ite (bvslt (read_gpr st rs1) (read_gpr st rs2)) ((_ zero_extend 63) (_ bv1 1)) ((_ zero_extend 63) (_ bv0 1))))

// The 13-bit immediate is sign-extended from its declared width; the program
// counter reads and writes through the dedicated state accessor.
// CHECK: ; INSTRUCTION: tbeq writes-pc=true rs1:reg:gpr:5 rs2:reg:gpr:5 imm:bits:13
// CHECK: (define-fun execute_tbeq
// CHECK-NEXT: (ite (= (read_gpr st rs1) (read_gpr st rs2)) (write_pc st (bvadd (pc st) ((_ sign_extend 51) ((_ extract 12 0) imm)))) st))

// A bare store statement is a state transition through the memory array.
// CHECK: (define-fun execute_tstore
// CHECK-NEXT: (write_mem_8 st (read_gpr st rs1) (read_gpr st rs2)))

// `~register` is a width-preserving bvnot; `~literal` folds to a signed
// constant (~1 = -2 = (_ bv6 3)) that sign-extends to all-ones-but-low-bit.
// CHECK: (define-fun execute_talign
// CHECK-NEXT: (write_gpr st rd (bvand (bvand (read_gpr st rs1) (bvnot (read_gpr st rs2))) ((_ sign_extend 61) (_ bv6 3)))))

// try/except has precise-trap semantics: the misalignment condition is bound
// over the entry state, the handler (mepc/mcause/mtval/pc trap setup) applies
// to the entry state, and the no-trap arm performs the load. Handler PC
// writes are trap entries, so the instruction still reads writes-pc=false.
// CHECK: ; INSTRUCTION: tload writes-pc=false rd:reg:gpr:5 rs1:reg:gpr:5 rs2:reg:gpr:5
// CHECK: (define-fun execute_tload
// CHECK-NEXT: (let ((exc_addr0 (bvadd (read_gpr st rs1) (read_gpr st rs2)))) (ite (distinct (bvand exc_addr0 (_ bv3 64)) (_ bv0 64)) (write_pc (write_csr (write_csr (write_csr st (_ bv833 12) (pc st)) (_ bv834 12) ((_ zero_extend 61) (_ bv4 3))) (_ bv835 12) exc_addr0) (bvshl (bvlshr (read_csr st (_ bv773 12)) ((_ zero_extend 62) (_ bv2 2))) ((_ zero_extend 62) (_ bv2 2)))) (write_gpr st rd ((_ sign_extend 32) (read_mem_4 st (bvadd (read_gpr st rs1) (read_gpr st rs2))))))))

// A `for` loop lowers to a first-class `Loop` node in the semantic graph; the
// SMT backend, which has no iteration, unrolls its constant bounds into the
// accumulator fold: rd becomes its entry value plus rs2 added four times.
// CHECK: ; INSTRUCTION: taccum writes-pc=false rd:reg:gpr:5 rs1:reg:gpr:5 rs2:reg:gpr:5
// CHECK: (define-fun execute_taccum
// CHECK-NEXT: (write_gpr (write_gpr st rd (read_gpr st rs1)) rd (bvadd (bvadd (bvadd (bvadd (read_gpr st rd) (read_gpr st rs2)) (read_gpr st rs2)) (read_gpr st rs2)) (read_gpr st rs2))))

// `trap()` delegates to the machine and stays out of the SMT model: marked,
// with identity semantics.
// CHECK: ; UNSUPPORTED-BEHAVIOR: ttrap
// CHECK: (define-fun execute_ttrap
// CHECK-NEXT: st)
