// RUN: tir mc --march=x86-64 --filetype=asm %s | filecheck %s

// AT&T assembly printing: `op src, dst`, `%` register sigil, two-address adds.

module {
  func @add(%0: !i64, %1: !i64) -> !i64 {
    %2 = addi %0, %1 : !i64
    return %2
  }
  module_end
}

// CHECK: .global add
// CHECK: add:
// CHECK: movq %rcx, %rax
// CHECK: addq %rdx, %rax
// CHECK: ret
