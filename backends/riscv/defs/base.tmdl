// RISC-V Base ISA instructions

template ALUOp for [RV32I, RV64I] : RType {
    param OPCODE: bits<7> = 0b0110011;
    param FUNCT7: bits<7> = 0b0000000;
    schedule { units = [WriteIALU]; }
}

template IALUOp for [RV32I, RV64I] : IType {
    param OPCODE: bits<7> = 0b0010011;
    schedule { units = [WriteIALU]; }
}

template ALUOpWord for [RV64I] : RTypeWord {
    param OPCODE: bits<7> = 0b0111011;
    param FUNCT7: bits<7> = 0b0000000;
    schedule { units = [WriteIALU]; }
}

template IALUOpWord for [RV64I] : ITypeWord {
    param OPCODE: bits<7> = 0b0011011;
    schedule { units = [WriteIALU]; }
}

instruction LoadUpperImm for [RV32I, RV64I] : UType {
    param MNEMONIC: String = "lui";
    param OPCODE: bits<7> = 0b0110111;

    behavior {
        rd = sext(imm, self.XLEN) << 12;
    }

    schedule { units = [WriteIALU]; }
}

instruction AddUpperImmToPC for [RV32I, RV64I] : UType {
    param MNEMONIC: String = "auipc";
    param OPCODE: bits<7> = 0b0010111;

    behavior {
        rd = PC::pc + (sext(imm, self.XLEN) << 12);
    }

    schedule { units = [WriteIALU]; }
}

instruction JumpAndLink for [RV32I, RV64I] : JType {
    param MNEMONIC: String = "jal";
    param OPCODE: bits<7> = 0b1101111;

    behavior {
        rd = PC::pc + zext(0b100, self.XLEN);
        PC::pc = PC::pc + sext(imm, self.XLEN);
    }

    schedule { units = [WriteIALU]; }
}

instruction JumpAndLinkReg for [RV32I, RV64I] : IType {
    param MNEMONIC: String = "jalr";
    param OPCODE: bits<7> = 0b1100111;
    param FUNCT3: bits<3> = 0b000;

    asm {
        "{self.MNEMONIC} {rd}, {imm}({rs1})"
    }

    behavior {
        rd = PC::pc + zext(0b100, self.XLEN);
        PC::pc = (rs1 + sext(imm, self.XLEN)) & ~1;
    }

    schedule { units = [WriteIALU]; }
}

template BranchOp for [RV32I, RV64I] : BType {
    param OPCODE: bits<7> = 0b1100011;
    schedule { units = [WriteIALU]; }
}

instruction BranchEq for [RV32I, RV64I] : BranchOp {
    param MNEMONIC: String = "beq";
    param FUNCT3: bits<3> = 0b000;

    behavior {
        if rs1 == rs2 {
            PC::pc = PC::pc + sext(imm, self.XLEN);
        }
    }
}

instruction BranchNotEq for [RV32I, RV64I] : BranchOp {
    param MNEMONIC: String = "bne";
    param FUNCT3: bits<3> = 0b001;

    behavior {
        if rs1 != rs2 {
            PC::pc = PC::pc + sext(imm, self.XLEN);
        }
    }
}

instruction BranchLt for [RV32I, RV64I] : BranchOp {
    param MNEMONIC: String = "blt";
    param FUNCT3: bits<3> = 0b100;

    behavior {
        if rs1 < rs2 {
            PC::pc = PC::pc + sext(imm, self.XLEN);
        }
    }
}

instruction BranchGe for [RV32I, RV64I] : BranchOp {
    param MNEMONIC: String = "bge";
    param FUNCT3: bits<3> = 0b101;

    behavior {
        if rs1 >= rs2 {
            PC::pc = PC::pc + sext(imm, self.XLEN);
        }
    }
}

instruction BranchLtUnsigned for [RV32I, RV64I] : BranchOp {
    param MNEMONIC: String = "bltu";
    param FUNCT3: bits<3> = 0b110;

    behavior {
        if rs1 ~< rs2 {
            PC::pc = PC::pc + sext(imm, self.XLEN);
        }
    }
}

instruction BranchGeUnsigned for [RV32I, RV64I] : BranchOp {
    param MNEMONIC: String = "bgeu";
    param FUNCT3: bits<3> = 0b111;

    behavior {
        if rs1 ~>= rs2 {
            PC::pc = PC::pc + sext(imm, self.XLEN);
        }
    }
}

instruction LoadByte for [RV32I, RV64I] : LoadInst {
    param MNEMONIC: String = "lb";
    param FUNCT3: bits<3> = 0b000;

    behavior {
        rd = sext(load(rs1 + sext(imm, self.XLEN), 1, 0b1), self.XLEN);
    }
}

instruction LoadHalfWord for [RV32I, RV64I] : LoadInst {
    param MNEMONIC: String = "lh";
    param FUNCT3: bits<3> = 0b001;

    behavior {
        rd = sext(load(rs1 + sext(imm, self.XLEN), 2, 0b1), self.XLEN);
    }
}

instruction LoadWord for [RV32I, RV64I] : LoadInst {
    param MNEMONIC: String = "lw";
    param FUNCT3: bits<3> = 0b010;

    behavior {
        rd = sext(load(rs1 + sext(imm, self.XLEN), 4, 0b1), self.XLEN);
    }
}

instruction LoadByteUnsigned for [RV32I, RV64I] : LoadInst {
    param MNEMONIC: String = "lbu";
    param FUNCT3: bits<3> = 0b100;

    behavior {
        rd = zext(load(rs1 + sext(imm, self.XLEN), 1, 0b0), self.XLEN);
    }
}

instruction LoadHalfWordUnsigned for [RV32I, RV64I] : LoadInst {
    param MNEMONIC: String = "lhu";
    param FUNCT3: bits<3> = 0b101;

    behavior {
        rd = zext(load(rs1 + sext(imm, self.XLEN), 2, 0b0), self.XLEN);
    }
}

instruction LoadWordUnsigned for [RV64I] : LoadInst {
    param MNEMONIC: String = "lwu";
    param FUNCT3: bits<3> = 0b110;

    behavior {
        rd = zext(load(rs1 + sext(imm, self.XLEN), 4, 0b0), self.XLEN);
    }
}

instruction LoadDoubleWord for [RV64I] : LoadInst {
    param MNEMONIC: String = "ld";
    param FUNCT3: bits<3> = 0b011;

    behavior {
        rd = load(rs1 + sext(imm, self.XLEN), 8, 0b0);
    }
}

instruction StoreByte for [RV32I, RV64I] : StoreInst {
    param MNEMONIC: String = "sb";
    param FUNCT3: bits<3> = 0b000;

    behavior {
        store(rs1 + sext(imm, self.XLEN), 1, extract(rs2, 7, 0));
    }
}

instruction StoreHalfWord for [RV32I, RV64I] : StoreInst {
    param MNEMONIC: String = "sh";
    param FUNCT3: bits<3> = 0b001;

    behavior {
        store(rs1 + sext(imm, self.XLEN), 2, extract(rs2, 15, 0));
    }
}

instruction StoreWord for [RV32I, RV64I] : StoreInst {
    param MNEMONIC: String = "sw";
    param FUNCT3: bits<3> = 0b010;

    behavior {
        store(rs1 + sext(imm, self.XLEN), 4, extract(rs2, 31, 0));
    }
}

instruction StoreDoubleWord for [RV64I] : StoreInst {
    param MNEMONIC: String = "sd";
    param FUNCT3: bits<3> = 0b011;

    behavior {
        store(rs1 + sext(imm, self.XLEN), 8, rs2);
    }
}

instruction Add for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "add";
    param FUNCT3: bits<3> = 0b000;

    behavior {
        rd = rs1 + rs2;
    }
}

instruction Sub for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "sub";
    param FUNCT3: bits<3> = 0b000;
    param FUNCT7: bits<7> = 0b0100000;

    behavior {
        rd = rs1 - rs2;
    }
}

instruction ShiftLeftLogical for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "sll";
    param FUNCT3: bits<3> = 0b001;

    behavior {
        rd = rs1 << extract(rs2, log2Ceil(self.XLEN) - 1, 0);
    }
}

instruction SetLessThan for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "slt";
    param FUNCT3: bits<3> = 0b010;

    behavior {
        rd = if rs1 < rs2 {
            zext(0b1, self.XLEN)
        } else {
            zext(0b0, self.XLEN)
        }
    }
}

instruction SetLessThanUnsigned for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "sltu";
    param FUNCT3: bits<3> = 0b011;

    behavior {
        rd = if rs1 ~< rs2 {
            zext(0b1, self.XLEN)
        } else {
            zext(0b0, self.XLEN)
        }
    }
}

instruction Xor for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "xor";
    param FUNCT3: bits<3> = 0b100;

    behavior {
        rd = rs1 ^ rs2;
    }
}

instruction ShiftRightLogical for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "srl";
    param FUNCT3: bits<3> = 0b101;

    behavior {
        rd = rs1 >> extract(rs2, log2Ceil(self.XLEN) - 1, 0);
    }
}

instruction ShiftRightArithmetic for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "sra";
    param FUNCT3: bits<3> = 0b101;
    param FUNCT7: bits<7> = 0b0100000;

    behavior {
        rd = rs1 >>> extract(rs2, log2Ceil(self.XLEN) - 1, 0);
    }
}

instruction Or for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "or";
    param FUNCT3: bits<3> = 0b110;

    behavior {
        rd = rs1 | rs2;
    }
}

instruction And for [RV32I, RV64I] : ALUOp {
    param MNEMONIC: String = "and";
    param FUNCT3: bits<3> = 0b111;

    behavior {
        rd = rs1 & rs2;
    }
}

instruction AddImm for [RV32I, RV64I] : IALUOp {
    param MNEMONIC: String = "addi";
    param FUNCT3: bits<3> = 0b000;

    behavior {
        rd = rs1 + sext(imm, self.XLEN);
    }
}

instruction SetLessThanImm for [RV32I, RV64I] : IALUOp {
    param MNEMONIC: String = "slti";
    param FUNCT3: bits<3> = 0b010;

    behavior {
        rd = if rs1 < sext(imm, self.XLEN) {
            zext(0b1, self.XLEN)
        } else {
            zext(0b0, self.XLEN)
        }
    }
}

instruction SetLessThanUnsignedImm for [RV32I, RV64I] : IALUOp {
    param MNEMONIC: String = "sltiu";
    param FUNCT3: bits<3> = 0b011;

    behavior {
        rd = if rs1 ~< zext(imm, self.XLEN) {
            zext(0b1, self.XLEN)
        } else {
            zext(0b0, self.XLEN)
        }
    }
}

instruction XorImm for [RV32I, RV64I] : IALUOp {
    param MNEMONIC: String = "xori";
    param FUNCT3: bits<3> = 0b100;

    behavior {
        rd = rs1 ^ sext(imm, self.XLEN);
    }
}

instruction OrImm for [RV32I, RV64I] : IALUOp {
    param MNEMONIC: String = "ori";
    param FUNCT3: bits<3> = 0b110;

    behavior {
        rd = rs1 | sext(imm, self.XLEN);
    }
}

instruction AndImm for [RV32I, RV64I] : IALUOp {
    param MNEMONIC: String = "andi";
    param FUNCT3: bits<3> = 0b111;

    behavior {
        rd = rs1 & sext(imm, self.XLEN);
    }
}

// Shift immediate forms

template ShiftImm for [RV32I, RV64I] {
    param OPCODE: bits<7> = 0b0010011;
    param MNEMONIC: String;
    param FUNCT3: bits<3>;
    param FUNCT6: bits<6>;

    operands {
        rd: GPR,
        rs1: GPR,
        imm: bits<6>,
    }

    encoding {
        0..6 => OPCODE,
        7..11 => rd,
        12..14 => FUNCT3,
        15..19 => rs1,
        20..25 => imm,
        26..31 => FUNCT6,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rs1}, {imm}"
    }
}

template ShiftImmWord64 for [RV64I] {
    param OPCODE: bits<7> = 0b0011011;
    param MNEMONIC: String;
    param FUNCT3: bits<3>;
    param FUNCT7: bits<7>;

    operands {
        rd: GPR,
        rs1: GPR,
        imm: bits<5>,
    }

    encoding {
        0..6 => OPCODE,
        7..11 => rd,
        12..14 => FUNCT3,
        15..19 => rs1,
        20..24 => imm,
        25..31 => FUNCT7,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rs1}, {imm}"
    }
}

instruction ShiftLeftLogicalImm for [RV32I, RV64I] : ShiftImm {
    param MNEMONIC: String = "slli";
    param FUNCT3: bits<3> = 0b001;
    param FUNCT6: bits<6> = 0b000000;

    behavior {
        rd = rs1 << extract(imm, log2Ceil(self.XLEN) - 1, 0);
    }
}

instruction ShiftRightLogicalImm for [RV32I, RV64I] : ShiftImm {
    param MNEMONIC: String = "srli";
    param FUNCT3: bits<3> = 0b101;
    param FUNCT6: bits<6> = 0b000000;

    behavior {
        rd = rs1 >> extract(imm, log2Ceil(self.XLEN) - 1, 0);
    }
}

instruction ShiftRightArithmeticImm for [RV32I, RV64I] : ShiftImm {
    param MNEMONIC: String = "srai";
    param FUNCT3: bits<3> = 0b101;
    param FUNCT6: bits<6> = 0b010000;

    behavior {
        rd = rs1 >>> extract(imm, log2Ceil(self.XLEN) - 1, 0);
    }
}

instruction AddImmWord for [RV64I] : IALUOpWord {
    param MNEMONIC: String = "addiw";
    param FUNCT3: bits<3> = 0b000;

    behavior {
        rd = sext(extract(rs1 + sext(imm, self.XLEN), 31, 0), self.XLEN);
    }
}

instruction ShiftLeftLogicalImmWord for [RV64I] : ShiftImmWord64 {
    param MNEMONIC: String = "slliw";
    param FUNCT3: bits<3> = 0b001;
    param FUNCT7: bits<7> = 0b0000000;

    behavior {
        rd = sext(extract(rs1 << imm, 31, 0), self.XLEN);
    }
}

instruction ShiftRightLogicalImmWord for [RV64I] : ShiftImmWord64 {
    param MNEMONIC: String = "srliw";
    param FUNCT3: bits<3> = 0b101;
    param FUNCT7: bits<7> = 0b0000000;

    behavior {
        rd = sext(extract(rs1 >> imm, 31, 0), self.XLEN);
    }
}

instruction ShiftRightArithmeticImmWord for [RV64I] : ShiftImmWord64 {
    param MNEMONIC: String = "sraiw";
    param FUNCT3: bits<3> = 0b101;
    param FUNCT7: bits<7> = 0b0100000;

    behavior {
        rd = sext(extract(rs1 >>> imm, 31, 0), self.XLEN);
    }
}

// SYSTEM instructions without operands; the whole encoding is fixed.
template SystemNoOperand for [RV32I, RV64I] {
    param MNEMONIC: String;
    param IMM12: bits<12>;
    param OPCODE: bits<7> = 0b1110011;

    encoding {
        0..6 => OPCODE,
        7..19 => 0,
        20..31 => IMM12,
    }

    asm {
        "{self.MNEMONIC}"
    }
}

instruction EnvCall for [RV32I, RV64I] : SystemNoOperand {
    param MNEMONIC: String = "ecall";
    param IMM12: bits<12> = 0b000000000000;

    behavior {
        // mcause 11: environment call from M-mode (the simulator's only mode).
        trap(11);
    }
}

instruction EnvBreak for [RV32I, RV64I] : SystemNoOperand {
    param MNEMONIC: String = "ebreak";
    param IMM12: bits<12> = 0b000000000001;

    behavior {
        // mcause 3: breakpoint.
        trap(3);
    }
}

instruction AddWord for [RV64I] : ALUOpWord {
    param MNEMONIC: String = "addw";
    param FUNCT3: bits<3> = 0b000;

    behavior {
        rd = sext(extract(rs1 + rs2, 31, 0), self.XLEN);
    }
}

instruction SubWord for [RV64I] : ALUOpWord {
    param MNEMONIC: String = "subw";
    param FUNCT3: bits<3> = 0b000;
    param FUNCT7: bits<7> = 0b0100000;

    behavior {
        rd = sext(extract(rs1 - rs2, 31, 0), self.XLEN);
    }
}

instruction ShiftLeftLogicalWord for [RV64I] : ALUOpWord {
    param MNEMONIC: String = "sllw";
    param FUNCT3: bits<3> = 0b001;

    behavior {
        rd = sext(extract(rs1 << clamp(rs2, 0, 31), 31, 0), self.XLEN);
    }
}

instruction ShiftRightLogicalWord for [RV64I] : ALUOpWord {
    param MNEMONIC: String = "srlw";
    param FUNCT3: bits<3> = 0b101;

    behavior {
        rd = sext(extract(rs1 >> clamp(rs2, 0, 31), 31, 0), self.XLEN);
    }
}

instruction ShiftRightArithmeticWord for [RV64I] : ALUOpWord {
    param MNEMONIC: String = "sraw";
    param FUNCT3: bits<3> = 0b101;
    param FUNCT7: bits<7> = 0b0100000;

    behavior {
        rd = sext(extract(rs1 >>> clamp(rs2, 0, 31), 31, 0), self.XLEN);
    }
}
