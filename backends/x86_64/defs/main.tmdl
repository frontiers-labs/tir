// x86-64 prototype, Intel syntax. Scope: the sixteen 64-bit GPRs with a fixed
// REX.W prefix. r8..r15 carry the 4th register-number bit in the REX prefix
// (REX.R for the ModR/M reg field, REX.B for the rm field); the low three bits
// stay in ModR/M. Register operands are spliced across both fields via slices,
// e.g. `dst[0..2]` and `dst[3]`.

isa X86_64 {
    param XLEN: Integer = 64;
}

isa X86 requires [X86_64] {}

register_class PC for [X86_64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = self.XLEN;

    registers {
        pc => { traits = [program_counter] },
    }
}

// Names carry no trailing digit, so each declares its register number.
register_class GPR for [X86_64] {
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = self.XLEN;

    registers {
        rax => { index = 0, traits = [return_value, caller_saved] },
        rcx => { index = 1, traits = [argument, caller_saved] },
        rdx => { index = 2, traits = [argument, return_value, caller_saved] },
        rbx => { index = 3, traits = [callee_saved] },
        rsp => { index = 4, traits = [stack_pointer, callee_saved] },
        rbp => { index = 5, traits = [callee_saved] },
        rsi => { index = 6, traits = [argument, caller_saved] },
        rdi => { index = 7, traits = [argument, caller_saved] },
        r8 => { index = 8, traits = [argument, caller_saved] },
        r9 => { index = 9, traits = [argument, caller_saved] },
        r10 => { index = 10, traits = [caller_saved] },
        r11 => { index = 11, traits = [caller_saved] },
        r12 => { index = 12, traits = [callee_saved] },
        r13 => { index = 13, traits = [callee_saved] },
        r14 => { index = 14, traits = [callee_saved] },
        r15 => { index = 15, traits = [callee_saved] },
    }
}

register_class GPR32 for [X86] : GPR {
    param WIDTH: Integer = 32;

    registers {
        eax => { index = 0, traits = [return_value, caller_saved] },
        ecx => { index = 1, traits = [argument, caller_saved] },
        edx => { index = 2, traits = [argument, return_value, caller_saved] },
        ebx => { index = 3, traits = [callee_saved] },
        esp => { index = 4, traits = [stack_pointer, callee_saved] },
        ebp => { index = 5, traits = [callee_saved] },
        esi => { index = 6, traits = [argument, caller_saved] },
        edi => { index = 7, traits = [argument, caller_saved] },
        r8d => { index = 8, traits = [argument, caller_saved] },
        r9d => { index = 9, traits = [argument, caller_saved] },
        r10d => { index = 10, traits = [caller_saved] },
        r11d => { index = 11, traits = [caller_saved] },
        r12d => { index = 12, traits = [callee_saved] },
        r13d => { index = 13, traits = [callee_saved] },
        r14d => { index = 14, traits = [callee_saved] },
        r15d => { index = 15, traits = [callee_saved] },
    }
}

// 16-bit operand size: the 0x66 prefix selects word width, register numbers are
// unchanged. Same physical file as GPR, so the indices alias the 64-bit names.
register_class GPR16 for [X86] : GPR {
    param WIDTH: Integer = 16;

    registers {
        ax => { index = 0, traits = [return_value, caller_saved] },
        cx => { index = 1, traits = [argument, caller_saved] },
        dx => { index = 2, traits = [argument, return_value, caller_saved] },
        bx => { index = 3, traits = [callee_saved] },
        sp => { index = 4, traits = [stack_pointer, callee_saved] },
        bp => { index = 5, traits = [callee_saved] },
        si => { index = 6, traits = [argument, caller_saved] },
        di => { index = 7, traits = [argument, caller_saved] },
        r8w => { index = 8, traits = [argument, caller_saved] },
        r9w => { index = 9, traits = [argument, caller_saved] },
        r10w => { index = 10, traits = [caller_saved] },
        r11w => { index = 11, traits = [caller_saved] },
        r12w => { index = 12, traits = [callee_saved] },
        r13w => { index = 13, traits = [callee_saved] },
        r14w => { index = 14, traits = [callee_saved] },
        r15w => { index = 15, traits = [callee_saved] },
    }
}

// Low byte of each GPR. The base four (al..bl) need no REX, but spl/bpl/sil/dil
// and r8b..r15b only exist when a REX prefix is present; the templates always
// emit one, so the whole class is uniformly encodable. Same file as GPR.
register_class GPR8 for [X86] : GPR {
    param WIDTH: Integer = 8;

    registers {
        al => { index = 0, traits = [return_value, caller_saved] },
        cl => { index = 1, traits = [argument, caller_saved] },
        dl => { index = 2, traits = [argument, return_value, caller_saved] },
        bl => { index = 3, traits = [callee_saved] },
        spl => { index = 4, traits = [stack_pointer, callee_saved] },
        bpl => { index = 5, traits = [callee_saved] },
        sil => { index = 6, traits = [argument, caller_saved] },
        dil => { index = 7, traits = [argument, caller_saved] },
        r8b => { index = 8, traits = [argument, caller_saved] },
        r9b => { index = 9, traits = [argument, caller_saved] },
        r10b => { index = 10, traits = [caller_saved] },
        r11b => { index = 11, traits = [caller_saved] },
        r12b => { index = 12, traits = [callee_saved] },
        r13b => { index = 13, traits = [callee_saved] },
        r14b => { index = 14, traits = [callee_saved] },
        r15b => { index = 15, traits = [callee_saved] },
    }
}

// High byte of the legacy four GPRs (bits 8..15 of rax/rcx/rdx/rbx). These
// overlap their enclosing 64-bit register, so for allocation aliasing they sit in
// the GPR file at the SAME indices as rax..rbx (0..3) — `file = GPR` shares that
// file without importing GPR's registers. Their ModR/M numbers are 4..7, which
// the no-REX templates form by setting the field's high bit, and they are
// encodable only WITHOUT a REX prefix (numbers 4..7 with REX would mean the low
// bytes spl/bpl/sil/dil instead).
register_class GPR8H for [X86] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 8;

    registers {
        ah => { index = 0, traits = [caller_saved] },
        ch => { index = 1, traits = [caller_saved] },
        dh => { index = 2, traits = [caller_saved] },
        bh => { index = 3, traits = [callee_saved] },
    }
}

// `op dst, src`: REX.W + opcode + ModR/M(mod=11, reg=src, rm=dst). The REX byte
// is 0100 WRXB: REX.B carries dst's 4th bit, REX.R carries src's.
template RegReg for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR,
        src: GPR,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => src[3],
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => OPCODE,
        16..18 => dst[0..2],
        19..21 => src[0..2],
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

// `op dst, imm32`: REX.W + opcode + ModR/M(mod=11, reg=EXT, rm=dst) + imm32. The
// reg field holds the /digit extension, so only REX.B (dst's 4th bit) varies.
template RegImm for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;
    param EXT: bits<3>;

    operands {
        dst: GPR,
        imm: bits<32>,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => OPCODE,
        16..18 => dst[0..2],
        19..21 => EXT,
        22..23 => 0b11,
        24..55 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

// `op dst, imm8`: REX.W + 0xC1 + ModR/M(mod=11, reg=EXT, rm=dst) + imm8.
template RegShift for [X86_64] {
    param MNEMONIC: String;
    param EXT: bits<3>;

    operands {
        dst: GPR,
        imm: bits<8>,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => 0xC1,
        16..18 => dst[0..2],
        19..21 => EXT,
        22..23 => 0b11,
        24..31 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

template RegReg32 for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR32,
        src: GPR32,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => src[3],
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => OPCODE,
        16..18 => dst[0..2],
        19..21 => src[0..2],
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

template RegImm32 for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;
    param EXT: bits<3>;

    operands {
        dst: GPR32,
        imm: bits<32>,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => OPCODE,
        16..18 => dst[0..2],
        19..21 => EXT,
        22..23 => 0b11,
        24..55 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

template RegShift32 for [X86] {
    param MNEMONIC: String;
    param EXT: bits<3>;

    operands {
        dst: GPR32,
        imm: bits<8>,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => 0xC1,
        16..18 => dst[0..2],
        19..21 => EXT,
        22..23 => 0b11,
        24..31 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

// 16-bit forms prepend the 0x66 operand-size prefix to the 32-bit encoding, so
// every field shifts up by one byte. The REX byte stays (W=0); immediates shrink
// to 16 bits.
template RegReg16 for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR16,
        src: GPR16,
    }

    encoding {
        0..7 => 0x66,
        8 => dst[3],
        9 => 0b0,
        10 => src[3],
        11 => 0b0,
        12..15 => 0b0100,
        16..23 => OPCODE,
        24..26 => dst[0..2],
        27..29 => src[0..2],
        30..31 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

template RegImm16 for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;
    param EXT: bits<3>;

    operands {
        dst: GPR16,
        imm: bits<16>,
    }

    encoding {
        0..7 => 0x66,
        8 => dst[3],
        9 => 0b0,
        10 => 0b0,
        11 => 0b0,
        12..15 => 0b0100,
        16..23 => OPCODE,
        24..26 => dst[0..2],
        27..29 => EXT,
        30..31 => 0b11,
        32..47 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

template RegShift16 for [X86] {
    param MNEMONIC: String;
    param EXT: bits<3>;

    operands {
        dst: GPR16,
        imm: bits<8>,
    }

    encoding {
        0..7 => 0x66,
        8 => dst[3],
        9 => 0b0,
        10 => 0b0,
        11 => 0b0,
        12..15 => 0b0100,
        16..23 => 0xC1,
        24..26 => dst[0..2],
        27..29 => EXT,
        30..31 => 0b11,
        32..39 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

// 8-bit forms reuse the 32-bit layout (REX always emitted, W=0) but take the
// byte-sized opcode, which is one less than the word/dword opcode for the ALU
// ops (0x80/0xC6/0xC0 for the immediate and shift groups). Immediates are 8-bit.
template RegReg8 for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR8,
        src: GPR8,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => src[3],
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => OPCODE,
        16..18 => dst[0..2],
        19..21 => src[0..2],
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

template RegImm8 for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;
    param EXT: bits<3>;

    operands {
        dst: GPR8,
        imm: bits<8>,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => OPCODE,
        16..18 => dst[0..2],
        19..21 => EXT,
        22..23 => 0b11,
        24..31 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

template RegShift8 for [X86] {
    param MNEMONIC: String;
    param EXT: bits<3>;

    operands {
        dst: GPR8,
        imm: bits<8>,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => 0xC0,
        16..18 => dst[0..2],
        19..21 => EXT,
        22..23 => 0b11,
        24..31 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

// High-byte forms carry no REX prefix, so the encoding is just opcode + ModR/M
// (+ immediate). The register index is its position in rax..rbx (0..3); the
// ModR/M number is that plus 4, formed here by setting the field's high bit.
template RegReg8H for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR8H,
        src: GPR8H,
    }

    encoding {
        0..7 => OPCODE,
        8..9 => dst[0..1],
        10 => 0b1,
        11..12 => src[0..1],
        13 => 0b1,
        14..15 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

template RegImm8H for [X86] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;
    param EXT: bits<3>;

    operands {
        dst: GPR8H,
        imm: bits<8>,
    }

    encoding {
        0..7 => OPCODE,
        8..9 => dst[0..1],
        10 => 0b1,
        11..13 => EXT,
        14..15 => 0b11,
        16..23 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

template RegShift8H for [X86] {
    param MNEMONIC: String;
    param EXT: bits<3>;

    operands {
        dst: GPR8H,
        imm: bits<8>,
    }

    encoding {
        0..7 => 0xC0,
        8..9 => dst[0..1],
        10 => 0b1,
        11..13 => EXT,
        14..15 => 0b11,
        16..23 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}
