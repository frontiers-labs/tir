// x86-64 prototype, Intel syntax. Scope: the eight base 64-bit GPRs, addressed
// by the 3-bit ModR/M field with a fixed REX.W prefix. r8..r15 are absent: their
// 4th register-number bit lives in the REX prefix, and TMDL cannot split a
// register operand across the REX byte and the ModR/M field.

isa X86_64 {
    param XLEN: Integer = 64;
}

register_class PC for [X86_64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = self.XLEN;

    registers {
        pc => { traits = [program_counter] },
    }
}

// Names carry no trailing digit, so each declares its register number.
register_class GPR for [X86_64] {
    param ENCODING_LEN: Integer = 3;
    param WIDTH: Integer = self.XLEN;

    registers {
        rax => { index = 0, traits = [return_value, caller_saved] },
        rcx => { index = 1, traits = [argument, caller_saved] },
        rdx => { index = 2, traits = [argument, return_value, caller_saved] },
        rbx => { index = 3, traits = [callee_saved] },
        rsp => { index = 4, traits = [stack_pointer, callee_saved] },
        rbp => { index = 5, traits = [callee_saved] },
        rsi => { index = 6, traits = [argument, caller_saved] },
        rdi => { index = 7, traits = [argument, caller_saved] },
    }
}

// `op dst, src`: REX.W + opcode + ModR/M(mod=11, reg=src, rm=dst).
template RegReg for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR,
        src: GPR,
    }

    encoding {
        0..7 => 0x48,
        8..15 => OPCODE,
        16..18 => dst,
        19..21 => src,
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

// `op dst, imm32`: REX.W + opcode + ModR/M(mod=11, reg=EXT, rm=dst) + imm32.
template RegImm for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;
    param EXT: bits<3>;

    operands {
        dst: GPR,
        imm: bits<32>,
    }

    encoding {
        0..7 => 0x48,
        8..15 => OPCODE,
        16..18 => dst,
        19..21 => EXT,
        22..23 => 0b11,
        24..55 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}

// `op dst, imm8`: REX.W + 0xC1 + ModR/M(mod=11, reg=EXT, rm=dst) + imm8.
template RegShift for [X86_64] {
    param MNEMONIC: String;
    param EXT: bits<3>;

    operands {
        dst: GPR,
        imm: bits<8>,
    }

    encoding {
        0..7 => 0x48,
        8..15 => 0xC1,
        16..18 => dst,
        19..21 => EXT,
        22..23 => 0b11,
        24..31 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }
}
