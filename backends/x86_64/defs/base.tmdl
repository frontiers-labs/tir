// Reg/reg and reg/imm forms share a mnemonic; the assembler tries forms in
// declaration order, so register forms precede the matching immediate forms.

instruction Add for [X86_64] : RegReg {
    param MNEMONIC: String = "add";
    param OPCODE: bits<8> = 0x01;

    behavior {
        dst = dst + src;
    }
}

instruction Sub for [X86_64] : RegReg {
    param MNEMONIC: String = "sub";
    param OPCODE: bits<8> = 0x29;

    behavior {
        dst = dst - src;
    }
}

instruction And for [X86_64] : RegReg {
    param MNEMONIC: String = "and";
    param OPCODE: bits<8> = 0x21;

    behavior {
        dst = dst & src;
    }
}

instruction Or for [X86_64] : RegReg {
    param MNEMONIC: String = "or";
    param OPCODE: bits<8> = 0x09;

    behavior {
        dst = dst | src;
    }
}

instruction Xor for [X86_64] : RegReg {
    param MNEMONIC: String = "xor";
    param OPCODE: bits<8> = 0x31;

    behavior {
        dst = dst ^ src;
    }
}

instruction Mov for [X86_64] : RegReg {
    param MNEMONIC: String = "mov";
    param OPCODE: bits<8> = 0x89;

    behavior {
        dst = src;
    }
}

// Group-1 ops share opcode 0x81 and select via the ModR/M EXT (/digit); mov
// uses 0xC7.

instruction AddImm for [X86_64] : RegImm {
    param OPNAME: String = "add_imm";
    param MNEMONIC: String = "add";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b000;

    behavior {
        dst = dst + sext(imm, self.XLEN);
    }
}

instruction OrImm for [X86_64] : RegImm {
    param OPNAME: String = "or_imm";
    param MNEMONIC: String = "or";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b001;

    behavior {
        dst = dst | sext(imm, self.XLEN);
    }
}

instruction AndImm for [X86_64] : RegImm {
    param OPNAME: String = "and_imm";
    param MNEMONIC: String = "and";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b100;

    behavior {
        dst = dst & sext(imm, self.XLEN);
    }
}

instruction XorImm for [X86_64] : RegImm {
    param OPNAME: String = "xor_imm";
    param MNEMONIC: String = "xor";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b110;

    behavior {
        dst = dst ^ sext(imm, self.XLEN);
    }
}

instruction MovImm for [X86_64] : RegImm {
    param OPNAME: String = "mov_imm";
    param MNEMONIC: String = "mov";
    param OPCODE: bits<8> = 0xC7;
    param EXT: bits<3> = 0b000;

    behavior {
        dst = sext(imm, self.XLEN);
    }
}

// Shift count masked to 6 bits for a 64-bit operand.

instruction ShlImm for [X86_64] : RegShift {
    param MNEMONIC: String = "shl";
    param EXT: bits<3> = 0b100;

    behavior {
        dst = dst << extract(imm, 5, 0);
    }
}

instruction ShrImm for [X86_64] : RegShift {
    param MNEMONIC: String = "shr";
    param EXT: bits<3> = 0b101;

    behavior {
        dst = dst >> extract(imm, 5, 0);
    }
}

instruction SarImm for [X86_64] : RegShift {
    param MNEMONIC: String = "sar";
    param EXT: bits<3> = 0b111;

    behavior {
        dst = dst >>> extract(imm, 5, 0);
    }
}

instruction Jmp for [X86_64] {
    param MNEMONIC: String = "jmp";

    operands {
        imm: bits<32>,
    }

    encoding {
        0..7 => 0xE9,
        8..39 => imm,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }

    behavior {
        PC::pc = PC::pc + sext(imm, self.XLEN);
    }
}

instruction Call for [X86_64] {
    param MNEMONIC: String = "call";

    operands {
        imm: bits<32>,
    }

    encoding {
        0..7 => 0xE8,
        8..39 => imm,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }

    behavior {
        GPR::rsp = GPR::rsp - zext(0b1000, self.XLEN);
        store(GPR::rsp, 8, PC::pc);
        PC::pc = PC::pc + sext(imm, self.XLEN);
    }
}

instruction Ret for [X86_64] {
    param MNEMONIC: String = "ret";

    encoding {
        0..7 => 0xC3,
    }

    asm {
        "{self.MNEMONIC}"
    }

    behavior {
        PC::pc = load(GPR::rsp, 8, 0b0);
        GPR::rsp = GPR::rsp + zext(0b1000, self.XLEN);
    }
}

instruction MovLoad for [X86_64] {
    param OPNAME: String = "mov_load";
    param MNEMONIC: String = "mov";

    operands {
        dst: GPR,
        base: GPR,
    }

    encoding {
        0 => base[3],
        1 => 0b0,
        2 => dst[3],
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => 0x8B,
        16..18 => base[0..2],
        19..21 => dst[0..2],
        22..23 => 0b00,
    }

    asm {
        "{self.MNEMONIC} {dst}, [{base}]"
    }

    behavior {
        dst = load(base, 8, 0b0);
    }
}

instruction MovStore for [X86_64] {
    param OPNAME: String = "mov_store";
    param MNEMONIC: String = "mov";

    operands {
        base: GPR,
        src: GPR,
    }

    encoding {
        0 => base[3],
        1 => 0b0,
        2 => src[3],
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => 0x89,
        16..18 => base[0..2],
        19..21 => src[0..2],
        22..23 => 0b00,
    }

    asm {
        "{self.MNEMONIC} [{base}], {src}"
    }

    behavior {
        store(base, 8, src);
    }
}

instruction JmpIndirect for [X86_64] {
    param OPNAME: String = "jmp_indirect";
    param MNEMONIC: String = "jmp";

    operands {
        target: GPR,
    }

    encoding {
        0 => target[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => 0xFF,
        16..18 => target[0..2],
        19..21 => 0b100,
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} *{target}"
    }

    behavior {
        PC::pc = target;
    }
}

instruction CallIndirect for [X86_64] {
    param OPNAME: String = "call_indirect";
    param MNEMONIC: String = "call";

    operands {
        target: GPR,
    }

    encoding {
        0 => target[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => 0xFF,
        16..18 => target[0..2],
        19..21 => 0b010,
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} *{target}"
    }

    behavior {
        GPR::rsp = GPR::rsp - zext(0b1000, self.XLEN);
        store(GPR::rsp, 8, PC::pc);
        PC::pc = target;
    }
}

